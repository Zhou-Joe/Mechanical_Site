# 油品检测记录系统环境变量配置模板
# 复制此文件为 .env 并修改相应配置

# ===========================================
# 数据库配置
# ===========================================
POSTGRES_DB=oil_inspection_db
POSTGRES_USER=oil_user
POSTGRES_PASSWORD=please_change_this_to_secure_password

# ===========================================
# Django应用配置
# ===========================================
DEBUG=False
SECRET_KEY=please-generate-a-new-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip,your-domain.com

# ===========================================
# 服务器配置
# ===========================================
# 主机端口映射（主机端口:容器端口）
WEB_PORT=8000
DB_PORT=5432

# ===========================================
# MinerU OCR服务配置
# ===========================================
MINERU_API_URL=http://localhost:8000/file_parse
MINERU_API_TIMEOUT=300

# ===========================================
# 邮件配置（可选）
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ===========================================
# 安全配置
# ===========================================
# 跨域设置（如果需要）
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# 会话安全设置
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True